{
  "name": "nuxt-component-preview",
  "version": "1.0.0-rc.4",
  "description": "A Nuxt module for component previewing functionality",
  "repository": "drunomics/nuxt-component-preview",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "lint": "eslint .",
    "test": "vitest run --exclude 'test/e2e/**'",
    "test:watch": "vitest watch --exclude 'test/e2e/**'",
    "test:e2e": "vitest run test/e2e --pool=threads --poolOptions.threads.maxThreads=1",
    "test:all": "npm run test && npm run test:e2e",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "vue-component-meta": "^3.2.6"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.0.0",
    "@nuxt/eslint-config": "^1.4.1",
    "@nuxt/kit": "^4.2.1",
    "@nuxt/module-builder": "^1.0.1",
    "@nuxt/schema": "^4.2.1",
    "@nuxt/test-utils": "^3.20.1",
    "@types/node": "latest",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.0",
    "happy-dom": "^20.0.11",
    "minimatch": "^10.0.3",
    "nuxt": "^4.2.1",
    "nuxtjs-drupal-ce": "^2.5.0-rc.2",
    "playwright-core": "^1.48.0",
    "typescript": "~5.9.0",
    "vitest": "^3.2.3",
    "vue-tsc": "^3.0.0"
  }
}
