{
  "version": "1.0",
  "components": [
    {
      "id": "TestButton",
      "name": "Test Button",
      "category": "Nuxt Components",
      "status": "stable",
      "props": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "title": "Label",
            "description": "Button label text",
            "default": "Click me",
            "examples": [
              "Submit",
              "Cancel",
              "Learn More"
            ]
          },
          "variant": {
            "type": "string",
            "title": "Variant",
            "description": "Visual style variant",
            "default": "primary",
            "enum": [
              "primary",
              "secondary",
              "danger",
              "success"
            ],
            "meta:enum": {
              "primary": "Primary",
              "secondary": "Secondary",
              "danger": "Danger",
              "success": "Success"
            },
            "examples": [
              "primary",
              "success"
            ]
          },
          "size": {
            "type": "string",
            "title": "Size",
            "description": "Button size",
            "default": "medium",
            "enum": [
              "medium",
              "small",
              "large"
            ],
            "meta:enum": {
              "medium": "Medium",
              "small": "Small",
              "large": "Large"
            },
            "examples": [
              "medium"
            ]
          },
          "disabled": {
            "type": "boolean",
            "title": "Disabled",
            "description": "Whether the button is disabled",
            "default": false
          }
        }
      }
    },
    {
      "id": "TestCard",
      "name": "Test Card",
      "category": "Nuxt Components",
      "status": "stable",
      "props": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Card title",
            "default": "Default Title",
            "examples": [
              "Featured Article",
              "Product Showcase"
            ]
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "Card description text",
            "default": "Default description",
            "examples": [
              "Learn more about our services",
              "Discover new features"
            ]
          }
        }
      }
    },
    {
      "id": "TestMarkup",
      "name": "Test Markup",
      "category": "Nuxt Components",
      "status": "stable",
      "props": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "title": "Content",
            "description": "HTML content to render",
            "default": 0
          }
        }
      }
    },
    {
      "id": "TestPopover",
      "name": "Test Popover",
      "category": "Nuxt Components",
      "status": "stable",
      "props": {
        "type": "object",
        "properties": {
          "placement": {
            "type": "string",
            "title": "Placement",
            "description": "Popover placement",
            "default": "bottom",
            "enum": [
              "bottom",
              "top",
              "left",
              "right",
              "top-start",
              "top-end",
              "bottom-start",
              "bottom-end"
            ],
            "meta:enum": {
              "bottom": "Bottom",
              "top": "Top",
              "left": "Left",
              "right": "Right",
              "top-start": "Top-start",
              "top-end": "Top-end",
              "bottom-start": "Bottom-start",
              "bottom-end": "Bottom-end"
            },
            "examples": [
              "bottom"
            ]
          },
          "trigger": {
            "type": "string",
            "title": "Trigger",
            "description": "Trigger type",
            "default": "click",
            "enum": [
              "click",
              "hover"
            ],
            "meta:enum": {
              "click": "Click",
              "hover": "Hover"
            },
            "examples": [
              "click"
            ]
          },
          "offset": {
            "type": "number",
            "title": "Offset",
            "description": "Offset in pixels",
            "default": 8,
            "examples": [
              8
            ]
          },
          "showArrow": {
            "type": "boolean",
            "title": "Show Arrow",
            "description": "Show arrow pointer",
            "default": true
          },
          "closeOnClickOutside": {
            "type": "boolean",
            "title": "Close On Click Outside",
            "description": "Close on click outside",
            "default": true
          },
          "delay": {
            "type": "number",
            "title": "Delay",
            "description": "Delay in milliseconds",
            "default": 0
          }
        }
      },
      "slots": {
        "trigger": {
          "title": "Trigger"
        }
      }
    },
    {
      "id": "TwoColumnLayout",
      "name": "Two Column Layout",
      "category": "Nuxt Components",
      "status": "stable",
      "props": {
        "type": "object",
        "properties": {
          "width": {
            "type": "integer",
            "title": "Width",
            "description": "First column width as percentage",
            "default": 50,
            "enum": [
              50,
              25,
              33,
              34,
              66,
              67,
              75
            ],
            "meta:enum": {
              "25": "25",
              "33": "33",
              "34": "34",
              "50": "50",
              "66": "66",
              "67": "67",
              "75": "75"
            },
            "examples": [
              33
            ]
          }
        }
      },
      "slots": {
        "column-one": {
          "title": "Column-one",
          "description": "First column content"
        },
        "column-two": {
          "title": "Column-two",
          "description": "Second column content"
        }
      }
    }
  ]
}